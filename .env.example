# =============================================================================
# LiteLLM Gateway — Environment Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Gateway admin
# -----------------------------------------------------------------------------

# Master key — admin/root access to the proxy. Use a strong random string in
# production: `openssl rand -hex 32` and prefix with "sk-".
LITELLM_MASTER_KEY=sk-CHANGE-ME

# -----------------------------------------------------------------------------
# Database (Postgres) — persists virtual keys, spend, model config, users
# -----------------------------------------------------------------------------

# Password for the bundled Postgres container. Generate with:
# `openssl rand -hex 24`
POSTGRES_PASSWORD=CHANGE-ME

# -----------------------------------------------------------------------------
# SSO (OIDC) — admin UI authentication via your company identity provider.
# LiteLLM speaks OIDC natively; no oauth2-proxy or other layer is involved.
# -----------------------------------------------------------------------------
# Register an OIDC application in your IdP with redirect URI:
#   <PROXY_BASE_URL>/sso/callback
# (For local dev with the bundled Dex: http://localhost:4000/sso/callback)
#
# API access on /v1/* etc. is unaffected — virtual keys handle auth there.
# SSO only gates the admin UI on /ui.

# Public URL of the gateway. Must match exactly what's registered with the IdP.
# Used by LiteLLM to build redirect URIs for the OAuth2 flow.
PROXY_BASE_URL=http://localhost:4000

GENERIC_CLIENT_ID=CHANGE-ME
GENERIC_CLIENT_SECRET=CHANGE-ME

# OIDC endpoints. With a real IdP (Okta/Google/Azure/Keycloak), all three
# point at the same public host. With the bundled Dex (--profile dev), the
# dev override file sets these for you — leave blank in .env.
#
# Examples by provider:
#   Okta:       https://<your-domain>.okta.com/oauth2/v1/{authorize,token,userinfo}
#   Google:     https://accounts.google.com/o/oauth2/v2/auth
#               https://oauth2.googleapis.com/token
#               https://openidconnect.googleapis.com/v1/userinfo
#   Azure AD:   https://login.microsoftonline.com/<tenant>/oauth2/v2.0/{authorize,token}
#               https://graph.microsoft.com/oidc/userinfo
#   Keycloak:   https://<host>/realms/<realm>/protocol/openid-connect/{auth,token,userinfo}
GENERIC_AUTHORIZATION_ENDPOINT=
GENERIC_TOKEN_ENDPOINT=
GENERIC_USERINFO_ENDPOINT=

# -----------------------------------------------------------------------------
# Model provider credentials — add the keys for the providers you want to route
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
