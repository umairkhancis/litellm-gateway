# =============================================================================
# LiteLLM Gateway — Environment Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Gateway admin
# -----------------------------------------------------------------------------

# Master key — admin/root access to the proxy. Use a strong random string in
# production: `openssl rand -hex 32` and prefix with "sk-".
LITELLM_MASTER_KEY=sk-CHANGE-ME

# Credentials for the LiteLLM admin UI at /ui
UI_USERNAME=admin
UI_PASSWORD=CHANGE-ME

# -----------------------------------------------------------------------------
# Database (Postgres) — persists virtual keys, spend, model config
# -----------------------------------------------------------------------------

# Password for the bundled Postgres container. Generate with:
# `openssl rand -hex 24`
POSTGRES_PASSWORD=CHANGE-ME

# -----------------------------------------------------------------------------
# Model provider credentials — add the keys for the providers you want to route
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
