# =============================================================================
# LiteLLM Gateway — Environment Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Gateway admin
# -----------------------------------------------------------------------------

# Master key — admin/root access to the proxy. Use a strong random string in
# production: `openssl rand -hex 32` and prefix with "sk-".
LITELLM_MASTER_KEY=sk-CHANGE-ME

# Credentials for the LiteLLM admin UI at /ui
UI_USERNAME=admin
UI_PASSWORD=CHANGE-ME

# -----------------------------------------------------------------------------
# Database (Postgres) — persists virtual keys, spend, model config
# -----------------------------------------------------------------------------

# Password for the bundled Postgres container. Generate with:
# `openssl rand -hex 24`
POSTGRES_PASSWORD=CHANGE-ME

# -----------------------------------------------------------------------------
# SSO (OIDC) — admin UI authentication via your company identity provider
# -----------------------------------------------------------------------------
# The admin UI on port 4180 is fronted by oauth2-proxy and requires SSO.
# Direct API access on port 4000 is unaffected (uses LiteLLM virtual keys).
#
# Register an OIDC application in your IdP with this redirect URI:
#   http://<gateway-host>:4180/oauth2/callback
# Then fill in the client ID/secret your IdP issued, and the issuer URL.

# Examples by provider (use the one that matches your IdP):
#   Okta:       https://<your-domain>.okta.com
#   Azure AD:   https://login.microsoftonline.com/<tenant-id>/v2.0
#   Google:     https://accounts.google.com
#   Keycloak:   https://<host>/realms/<realm>
#   Local dev:  http://localhost:5556  (bundled Dex; --profile dev)
OIDC_ISSUER_URL=http://localhost:5556
OIDC_CLIENT_ID=litellm-gateway
OIDC_CLIENT_SECRET=CHANGE-ME

# Where the IdP redirects after login. Must exactly match what's registered
# in the IdP application. For local dev: http://localhost:4180/oauth2/callback
OAUTH2_REDIRECT_URL=http://localhost:4180/oauth2/callback

# Cookie encryption secret for oauth2-proxy. Generate with:
#   openssl rand -base64 32 | tr -- '+/' '-_'
OAUTH2_COOKIE_SECRET=CHANGE-ME

# -----------------------------------------------------------------------------
# Model provider credentials — add the keys for the providers you want to route
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
