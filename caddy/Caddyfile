{
	# Local CA only — mkcert handles trust, no Let's Encrypt for .test TLDs.
	auto_https off
}

# Gateway: terminates TLS, forwards to LiteLLM on :4000.
litellm.umairkhancis.test {
	tls /certs/gateway.pem /certs/gateway-key.pem
	reverse_proxy litellm:4000
}

# IdP: terminates TLS, forwards to Dex on :5556. Reachable from the host
# browser AND from the litellm container via docker network alias, so the
# OIDC issuer claim matches in both directions — like a real Okta tenant.
dex.umairkhancis.test {
	tls /certs/gateway.pem /certs/gateway-key.pem
	reverse_proxy dex:5556
}
